<%
  resource_labels = {
    "Product" => "Productos",
    "Provider" => "Proveedores",
    "Customer" => "Clientes"
  }
  resource_label = resource_labels[@resource_type] || @resource_type
%>

<% content_for :page_title, "Historial de Importaciones" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-end gap-3 mb-6">
    <%= link_to new_bulk_import_path(resource_type: @resource_type),
                class: "btn-primary inline-flex items-center gap-2" do %>
      <%= app_icon("cloud-upload", class: "w-4 h-4") %>
      Nueva Importacion
    <% end %>
  </div>

  <%# Tabs for resource type %>
  <div class="border-b border-border mb-6">
    <nav class="-mb-px flex space-x-8">
      <%= link_to bulk_imports_path(resource_type: "Product"),
                  class: "tab-link #{@resource_type == 'Product' ? 'tab-link-active' : ''}" do %>
        Productos
      <% end %>
      <%= link_to bulk_imports_path(resource_type: "Provider"),
                  class: "tab-link #{@resource_type == 'Provider' ? 'tab-link-active' : ''}" do %>
        Proveedores
      <% end %>
      <%= link_to bulk_imports_path(resource_type: "Customer"),
                  class: "tab-link #{@resource_type == 'Customer' ? 'tab-link-active' : ''}" do %>
        Clientes
      <% end %>
    </nav>
  </div>

  <% if @bulk_imports.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">Fecha</th>
              <th class="table-th text-left">Usuario</th>
              <th class="table-th text-left">Archivo</th>
              <th class="table-th text-center">Estado</th>
              <th class="table-th text-center">Exitosos</th>
              <th class="table-th text-center">Fallidos</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @bulk_imports.each do |import| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-foreground">
                  <%= import.created_at.strftime("%d/%m/%Y %H:%M") %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-foreground">
                  <%= import.user.first_name %> <%= import.user.first_last_name %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-muted-foreground">
                  <%= import.original_filename || "Sin nombre" %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-center">
                  <%= render_import_status_badge(import.status) %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-center">
                  <span class="text-green-600 dark:text-green-400 font-medium">
                    <%= import.successful_rows %>
                  </span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-center">
                  <span class="<%= import.failed_rows > 0 ? 'text-red-600 dark:text-red-400 font-medium' : 'text-muted-foreground' %>">
                    <%= import.failed_rows %>
                  </span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm">
                  <%= link_to bulk_import_path(import), class: "table-action-btn", title: "Ver detalles" do %>
                    <%= app_icon("eye", class: "w-4 h-4") %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border bg-muted/30">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <div class="mx-auto w-12 h-12 rounded-lg bg-muted flex items-center justify-center mb-3">
        <%= app_icon("cloud-upload", class: "w-6 h-6 text-muted-foreground") %>
      </div>
      <h3 class="text-sm font-medium text-foreground">No hay importaciones</h3>
      <p class="mt-1 text-sm text-muted-foreground">Realiza tu primera importacion masiva.</p>
      <div class="mt-4">
        <%= link_to new_bulk_import_path(resource_type: @resource_type),
                    class: "btn-primary inline-flex items-center gap-2" do %>
          <%= app_icon("plus", class: "w-4 h-4") %>
          Nueva Importacion
        <% end %>
      </div>
    </div>
  <% end %>
</div>
