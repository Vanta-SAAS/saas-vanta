<% content_for :page_title, "Proveedores" %>
<% add_breadcrumb "Compras" %>
<% add_breadcrumb "Proveedores" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between gap-3 mb-6">
    <div class="w-full max-w-sm">
      <%= render "shared/table/search_bar", url: providers_path, placeholder: "Buscar por nombre o RUC..." %>
    </div>
    <div class="flex items-center gap-3">
    <% if policy(Provider).create? %>
      <%= link_to new_bulk_import_path(resource_type: "Provider"), class: "btn-secondary inline-flex items-center gap-2" do %>
        <%= app_icon("cloud-upload", class: "w-4 h-4") %>
        Importar
      <% end %>
      <%= link_to new_provider_path, class: "btn-primary inline-flex items-center gap-2" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Agregar Proveedor
      <% end %>
    <% end %>
    </div>
  </div>

  <% if @providers.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">Proveedor</th>
              <th class="table-th text-left">RUC/DNI</th>
              <th class="table-th text-left">Email</th>
              <th class="table-th text-left">Telefono</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @providers.each do |provider| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <%= table_cell_primary(provider.name, nil, provider) %>
                <%= table_cell_code(provider.tax_id) %>
                <%= table_cell(provider.email.presence || "-") %>
                <%= table_cell(provider.phone_number.presence || "-") %>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to provider, class: "table-action-btn", title: "Ver" do %>
                      <%= app_icon("eye", class: "w-4 h-4") %>
                    <% end %>
                    <% if policy(provider).update? %>
                      <%= link_to edit_provider_path(provider), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                    <% if policy(provider).destroy? %>
                      <%= button_to provider, method: :delete, class: "table-action-btn-danger", title: "Eliminar", data: { turbo_confirm: "¿Estas seguro de eliminar este proveedor?" } do %>
                        <%= app_icon("trash", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :truck,
      title: "No hay proveedores",
      description: "Comienza agregando tu primer proveedor.",
      action_path: new_provider_path,
      action_label: "Nuevo Proveedor",
      show_action: policy(Provider).create? %>
  <% end %>
</div>
