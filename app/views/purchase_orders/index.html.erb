<% content_for :page_title, "Ordenes de Compra" %>
<% add_breadcrumb "Compras" %>
<% add_breadcrumb "Ordenes de Compra" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between gap-3 mb-6">
    <div class="w-full max-w-sm">
      <%= render "shared/table/search_bar", url: purchase_orders_path, placeholder: "Buscar por codigo o proveedor..." %>
    </div>
    <% if policy(PurchaseOrder).create? %>
      <%= link_to new_purchase_order_path, class: "btn-primary" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Nueva Orden
      <% end %>
    <% end %>
  </div>

  <% if @purchase_orders.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead>
            <tr class="bg-muted/40">
              <th class="table-th text-left">Codigo</th>
              <th class="table-th text-left">Proveedor</th>
              <th class="table-th text-left">Fecha</th>
              <th class="table-th text-right">Total</th>
              <th class="table-th text-center">Estado</th>
              <th class="table-th text-left">Creado por</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @purchase_orders.each do |order| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm font-medium text-foreground font-mono"><%= order.code %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm font-medium text-foreground"><%= order.provider.name %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= l(order.issue_date, format: :short) %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right">
                  <span class="text-sm font-medium text-foreground tabular-nums">S/ <%= number_with_precision(order.total, precision: 2, delimiter: ",") %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-center">
                  <span class="<%= order.status_badge_class %>"><%= order.status_label %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= order.created_by.first_name %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to order, class: "table-action-btn", title: "Ver" do %>
                      <%= app_icon("eye", class: "w-4 h-4") %>
                    <% end %>
                    <% if order.draft? && policy(order).update? %>
                      <%= link_to edit_purchase_order_path(order), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :document,
      title: "No hay ordenes de compra",
      description: "Comienza creando tu primera orden de compra.",
      action_path: new_purchase_order_path,
      action_label: "Nueva Orden",
      show_action: policy(PurchaseOrder).create? %>
  <% end %>
</div>
