<% content_for :page_title, "Clientes" %>
<% add_breadcrumb "Catalogo" %>
<% add_breadcrumb "Clientes" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between gap-3 mb-6">
    <div class="w-full max-w-sm">
      <%= render "shared/table/search_bar", url: customers_path, placeholder: "Buscar por nombre o documento..." %>
    </div>
    <div class="flex items-center gap-3">
    <% if policy(Customer).create? %>
      <%= link_to new_bulk_import_path(resource_type: "Customer"), class: "btn-secondary inline-flex items-center gap-2" do %>
        <%= app_icon("cloud-upload", class: "w-4 h-4") %>
        Importar
      <% end %>
      <%= link_to new_customer_path, class: "btn-primary inline-flex items-center gap-2" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Agregar Cliente
      <% end %>
    <% end %>
    </div>
  </div>

  <% if @customers.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">Cliente</th>
              <th class="table-th text-left">Documento</th>
              <th class="table-th text-left">Email</th>
              <th class="table-th text-left">Telefono</th>
              <th class="table-th text-right">Limite Credito</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @customers.each do |customer| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <%= table_cell_primary(customer.name, nil, customer) %>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-foreground">
                  <% if customer.tax_id.present? %>
                    <span class="inline-flex items-center gap-1">
                      <span class="text-xs font-medium text-muted-foreground uppercase"><%= customer.tax_id_type %></span>
                      <span class="font-mono"><%= customer.tax_id %></span>
                    </span>
                  <% else %>
                    <span class="text-muted-foreground">-</span>
                  <% end %>
                </td>
                <%= table_cell(customer.email.presence || "-") %>
                <%= table_cell(customer.phone_number.presence || "-") %>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-foreground text-right font-mono">
                  <% if customer.credit_limit > 0 %>
                    S/ <%= number_with_precision(customer.credit_limit, precision: 2, delimiter: ",") %>
                  <% else %>
                    <span class="text-muted-foreground">-</span>
                  <% end %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to customer, class: "table-action-btn", title: "Ver" do %>
                      <%= app_icon("eye", class: "w-4 h-4") %>
                    <% end %>
                    <% if policy(customer).update? %>
                      <%= link_to edit_customer_path(customer), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                    <% if policy(customer).destroy? %>
                      <%= button_to customer, method: :delete, class: "table-action-btn-danger", title: "Eliminar", data: { turbo_confirm: "¿Estas seguro de eliminar este cliente?" } do %>
                        <%= app_icon("trash", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :users,
      title: "No hay clientes",
      description: "Comienza agregando tu primer cliente.",
      action_path: new_customer_path,
      action_label: "Nuevo Cliente",
      show_action: policy(Customer).create? %>
  <% end %>
</div>
