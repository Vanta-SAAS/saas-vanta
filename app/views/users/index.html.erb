<% content_for :page_title, "Usuarios" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-end gap-3 mb-6">
    <% if policy(User).create? %>
      <%= link_to new_user_path, class: "btn-primary inline-flex items-center gap-2" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Agregar Usuario
      <% end %>
    <% end %>
  </div>

  <% if @users.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">Usuario</th>
              <th class="table-th text-left">Email</th>
              <th class="table-th text-left">Rol</th>
              <th class="table-th text-center">Estado</th>
              <th class="table-th text-left">Fecha de Registro</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @users.each do |user| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <div class="flex items-center gap-3">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                      <span class="text-sm font-semibold text-primary">
                        <%= user.first_name&.first&.upcase %><%= user.first_last_name&.first&.upcase %>
                      </span>
                    </div>
                    <div>
                      <div class="text-sm font-medium text-foreground">
                        <%= link_to "#{user.first_name} #{user.first_last_name}", user, class: "hover:text-primary" %>
                      </div>
                      <% if user.phone_number.present? %>
                        <div class="text-xs text-muted-foreground"><%= user.phone_number %></div>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-muted-foreground">
                  <%= user.email_address %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <div class="flex flex-wrap gap-1">
                    <% user.roles_for(current_enterprise).each do |role| %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= role_badge_class(role) %>">
                        <%= role_label(role) %>
                      </span>
                    <% end %>
                  </div>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-center">
                  <%= render_user_status_badge(user.status) %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-muted-foreground">
                  <%= user.created_at.strftime("%d/%m/%Y") %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to user, class: "table-action-btn", title: "Ver" do %>
                      <%= app_icon("eye", class: "w-4 h-4") %>
                    <% end %>
                    <% if policy(user).edit? %>
                      <%= link_to edit_user_path(user), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                    <% if policy(user).toggle_status? %>
                      <% if user.active? %>
                        <%= button_to toggle_status_user_path(user), method: :patch, class: "table-action-btn-danger", title: "Desactivar", data: { turbo_confirm: "¿Estás seguro de desactivar a este usuario?" } do %>
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                          </svg>
                        <% end %>
                      <% else %>
                        <%= button_to toggle_status_user_path(user), method: :patch, class: "table-action-btn text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300 hover:bg-green-50 dark:hover:bg-green-900/20", title: "Activar" do %>
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :users,
      title: "No hay usuarios",
      description: "Comienza agregando tu primer usuario.",
      action_path: new_user_path,
      action_label: "Nuevo Usuario",
      show_action: policy(User).create? %>
  <% end %>
</div>
