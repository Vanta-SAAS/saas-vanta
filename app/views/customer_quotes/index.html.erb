<% content_for :page_title, "Cotizaciones" %>
<% add_breadcrumb "Comercial" %>
<% add_breadcrumb "Cotizaciones" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between gap-3 mb-6">
    <div class="w-full max-w-sm">
      <%= render "shared/table/search_bar", url: customer_quotes_path, placeholder: "Buscar por codigo o cliente..." %>
    </div>
    <% if policy(CustomerQuote).create? %>
      <%= link_to new_customer_quote_path, class: "btn-primary" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Nueva Cotizacion
      <% end %>
    <% end %>
  </div>

  <% if @customer_quotes.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead>
            <tr class="bg-muted/40">
              <th class="table-th text-left">Codigo</th>
              <th class="table-th text-left">Cliente</th>
              <th class="table-th text-left">Vendedor</th>
              <th class="table-th text-left">Fecha</th>
              <th class="table-th text-right">Total</th>
              <th class="table-th text-center">Estado</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @customer_quotes.each do |quote| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm font-medium text-foreground font-mono"><%= quote.code %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm font-medium text-foreground"><%= quote.customer.name %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= quote.seller.first_name %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= l(quote.issue_date, format: :short) %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right">
                  <span class="text-sm font-medium text-foreground tabular-nums">S/ <%= number_with_precision(quote.total, precision: 2, delimiter: ",") %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-center">
                  <span class="<%= quote.status_badge_class %>"><%= quote.status_label %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to quote, class: "table-action-btn", title: "Ver" do %>
                      <%= app_icon("eye", class: "w-4 h-4") %>
                    <% end %>
                    <% if quote.pending? && policy(quote).update? %>
                      <%= link_to edit_customer_quote_path(quote), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :document,
      title: "No hay cotizaciones",
      description: "Comienza creando tu primera cotizacion.",
      action_path: new_customer_quote_path,
      action_label: "Nueva Cotizacion",
      show_action: policy(CustomerQuote).create? %>
  <% end %>
</div>
