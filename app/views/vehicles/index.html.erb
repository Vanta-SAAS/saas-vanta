<% content_for :page_title, "Vehiculos" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-end gap-3 mb-6">
    <% if policy(Vehicle).create? %>
      <%= link_to new_vehicle_path, class: "btn-primary inline-flex items-center gap-2" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Nuevo Vehiculo
      <% end %>
    <% end %>
  </div>

  <% if @vehicles.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">Placa</th>
              <th class="table-th text-left">Marca</th>
              <th class="table-th text-left">Modelo</th>
              <th class="table-th text-left">Estado</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @vehicles.each do |vehicle| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap text-sm font-medium text-foreground"><%= vehicle.plate %></td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-muted-foreground"><%= vehicle.brand.presence || "-" %></td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-muted-foreground"><%= vehicle.model.presence || "-" %></td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="<%= vehicle.active? ? 'badge-success' : 'badge-secondary' %>"><%= vehicle.active? ? 'Activo' : 'Inactivo' %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-1">
                    <% if policy(vehicle).update? %>
                      <%= link_to edit_vehicle_path(vehicle), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                    <% if policy(vehicle).destroy? %>
                      <%= button_to vehicle, method: :delete, class: "table-action-btn-danger", title: "Eliminar", data: { turbo_confirm: "Estas seguro de eliminar este vehiculo?" } do %>
                        <%= app_icon("trash", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border bg-muted/30">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :truck,
      title: "No hay vehiculos",
      description: "Comienza registrando tu primer vehiculo.",
      action_path: new_vehicle_path,
      action_label: "Nuevo Vehiculo",
      show_action: policy(Vehicle).create? %>
  <% end %>
</div>
