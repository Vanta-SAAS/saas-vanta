<%= form_with(model: vehicle, class: "space-y-6") do |f| %>
  <% if vehicle.errors.any? %>
    <div class="alert-error">
      <ul class="list-disc list-inside text-sm">
        <% vehicle.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <h3 class="text-sm font-semibold text-foreground mb-3">Datos del Vehiculo</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :plate, class: "form-label" do %>
          Placa <span class="required-mark">*</span>
        <% end %>
        <%= f.text_field :plate, class: form_field_class(vehicle, :plate), required: true, placeholder: "ABC-123" %>
        <%= form_field_errors(vehicle, :plate) %>
      </div>

      <div>
        <%= f.label :status, "Estado", class: "form-label" %>
        <%= f.select :status, [["Activo", "active"], ["Inactivo", "inactive"]], {}, class: "form-input" %>
      </div>

      <div>
        <%= f.label :brand, class: "form-label" do %>
          Marca <span class="text-muted-foreground font-normal">(opcional)</span>
        <% end %>
        <%= f.text_field :brand, class: "form-input", placeholder: "Toyota" %>
      </div>

      <div>
        <%= f.label :model, class: "form-label" do %>
          Modelo <span class="text-muted-foreground font-normal">(opcional)</span>
        <% end %>
        <%= f.text_field :model, class: "form-input", placeholder: "Hilux" %>
      </div>
    </div>
  </div>

  <div class="flex items-end justify-end gap-3">
    <%= f.submit vehicle.persisted? ? "Actualizar Vehiculo" : "Registrar Vehiculo", class: "btn-primary cursor-pointer", data: { turbo_submits_with: "Guardando..." } %>
  </div>
<% end %>
